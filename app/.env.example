# FinIQ Environment Configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
NODE_ENV=development

# Data Mode (simulated | databricks)
# simulated = use SQLite fallback
# databricks = connect to real Databricks workspace
DATA_MODE=simulated

# Databricks Connection (Synthetic workspace for testing)
DATABRICKS_SERVER_HOSTNAME=dbc-af05a0e0-4ebe.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id-here
DATABRICKS_ACCESS_TOKEN=your-databricks-token-here
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default

# Databricks Connection (Production - Real Mode)
# DATABRICKS_CATALOG_PROD=corporate_finance_analytics_dev
# DATABRICKS_SCHEMA_PROD=finsight_core_model_mvp3

# SQLite Fallback (Simulated Mode)
SQLITE_DB_PATH=../finiq_synthetic.db

# Anthropic Claude API (for LLM-powered agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure OpenAI (alternative LLM - not used in Phase 1.5)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Authentication (optional for MVP)
AUTH_ENABLED=false
AUTH_TOKEN=your-secret-token-here

# Logging
LOG_LEVEL=info

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
