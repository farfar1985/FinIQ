# ============================================================
# FinIQ Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Data Mode ---
# "simulated" = SQLite fallback (default, zero dependencies)
# "databricks" = Live Databricks connection
DATA_MODE=simulated
SQLITE_PATH=../finiq_synthetic.db

# --- Databricks (when DATA_MODE=databricks) ---
DATABRICKS_SERVER_HOSTNAME=dbc-af05a0e0-4ebe.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse_id>
DATABRICKS_TOKEN=<your_databricks_token>
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default

# --- Anthropic (NL queries, summarization) ---
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# --- Financial Modeling Prep (CI module) ---
FMP_API_KEY=<your_fmp_api_key>

# --- Rate limiting ---
RATE_LIMIT_RPM=100
RATE_LIMIT_CHAT_RPM=10

# --- Server ---
PORT=3001
NODE_ENV=development
